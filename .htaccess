# SYR Connect Device Emulator - Apache Configuration

# Enable rewrite engine
RewriteEngine On

# Set base directory (update if deployed in subdirectory)
RewriteBase /

# Don't rewrite requests for existing files or directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route device-specific API requests to index.php
# Supported devices: neosoft, trio
RewriteRule ^(neosoft|trio)/(.*)$ index.php [QSA,L]

# Enable CORS for testing (remove in production)
Header set Access-Control-Allow-Origin "*"
Header set Access-Control-Allow-Methods "GET, POST, OPTIONS"
Header set Access-Control-Allow-Headers "Content-Type"

# Set default content type to JSON
<FilesMatch "\.(php)$">
    Header set Content-Type "application/json; charset=utf-8"
</FilesMatch>

# Disable directory listing
Options -Indexes

# Protect sensitive files
<FilesMatch "^(set_operations\.log|devices/.*)$">
    Order allow,deny
    Deny from all
</FilesMatch>
