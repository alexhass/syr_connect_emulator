# SYR Connect Device Emulator - Apache Configuration

# Enable rewrite engine
RewriteEngine On

# Set base directory (update if deployed in subdirectory)
RewriteBase /

# Route device-specific API requests to index.php
# Supported devices: neosoft, trio, pontos-base
# Supported endpoints:
#   /{device}/set/ADM/(2)f       - Login
#   /{device}/get/all            - Get all values
#   /{device}/get/{key}          - Get single value
#   /{device}/set/{key}/{value}  - Set value
#
# The path is passed via the _dp query parameter so that Apache URL-encodes
# special characters (e.g. ':' in time values like '2:00' -> '%3A00') rather
# than running the value through Windows path normalization, which would
# truncate it at the colon (NTFS alternate data stream syntax).
RewriteRule ^(neosoft|safe-tec|trio|pontos-base)/(.*)$ index.php?_dp=$1/$2 [QSA,L]

# Suppress Apache default headers to match real device
# Real device only sends: HTTP/1.1 200 OK + content-length: XX
<IfModule mod_headers.c>
    Header always unset Date
    Header always unset Server
    Header always unset X-Powered-By
    Header always unset Content-Type
</IfModule>

# Disable directory listing
Options -Indexes

# Protect sensitive files
<FilesMatch "^(set_operations\.log|devices/.*)$">
    Order allow,deny
    Deny from all
</FilesMatch>
