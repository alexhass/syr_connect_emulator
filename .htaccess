# SYR Connect Device Emulator - Apache Configuration

# Enable rewrite engine
RewriteEngine On

# Set base directory (update if deployed in subdirectory)
RewriteBase /

# Don't rewrite requests for existing files or directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route device-specific API requests to index.php
# Supported devices: neosoft, trio, pontos-base
# Supported endpoints:
#   /{device}/set/ADM/(2)f       - Login
#   /{device}/get/all            - Get all values
#   /{device}/get/{key}          - Get single value
#   /{device}/set/{key}/{value}  - Set value
RewriteRule ^(neosoft|trio|pontos-base)/(.*)$ index.php [QSA,L]

# Suppress Apache default headers to match real device
# Real device only sends: HTTP/1.1 200 OK + content-length: XX
<IfModule mod_headers.c>
    Header always unset Date
    Header always unset Server
    Header always unset X-Powered-By
    Header always unset Content-Type
</IfModule>

# Disable directory listing
Options -Indexes

# Protect sensitive files
<FilesMatch "^(set_operations\.log|devices/.*)$">
    Order allow,deny
    Deny from all
</FilesMatch>
